# ─────────────────────────────────────────────────────────────
# 김비서 템플릿 환경변수
# 이 파일을 복사해서 `.env.local` 을 만들고 값을 채우세요.
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────

# [필수] Supabase 연결 정보
# Supabase 대시보드 > Project Settings > API 에서 복사합니다.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# [참고] DB 비밀번호 — 앱 실행에는 쓰이지 않습니다.
# `supabase link` / `supabase db push` 등 CLI 작업에 필요해 기록용으로 보관합니다.
# 초기 설정을 Claude Code 로 진행하면 자동 생성되어 여기에 저장됩니다. (🔒 외부 공유 금지)
SUPABASE_DB_PASSWORD=

# [필수] 로그인 이메일 도메인
# 로그인 ID 뒤에 붙는 가상 이메일 도메인입니다. (예: admin → admin@example.com)
# 그대로 두어도 됩니다.
NEXT_PUBLIC_AUTH_EMAIL_DOMAIN=example.com

# ─────────────────────────────────────────────────────────────
# 아래는 모두 [선택] 입니다. 비워두면 해당 기능만 동작하지 않을 뿐,
# 앱은 정상적으로 실행됩니다. 대부분의 키는 앱 실행 후
# [시스템설정] 화면에서 입력할 수도 있습니다.
# ─────────────────────────────────────────────────────────────

# (선택) 명함관리 OCR / 입금 AI매칭 / AI견적 - Google Gemini
# 시스템설정 화면에서 입력하는 것을 권장합니다.
# GEMINI_API_KEY=

# (선택) AI 견적 생성 / 미팅 자동매칭 - Anthropic Claude
# ⚠️ 이 키는 시스템설정 화면에 입력란이 없어 .env.local 에만 넣을 수 있습니다.
# ANTHROPIC_API_KEY=

# (선택) Google Drive 연동 — 고객/프로젝트 생성 시 Drive 폴더 자동 생성·파일 업로드.
# 기본은 꺼져 있습니다. 켜려면 아래를 모두 채우세요. (자세한 절차: docs/GOOGLE_DRIVE_SETUP.md)
#   1) NEXT_PUBLIC_DRIVE_ENABLED 를 true 로
#   2) 서비스 계정 이메일/키 (Google Cloud 서비스 계정 + Drive API 활성화)
#   3) GOOGLE_DRIVE_ROOT_FOLDER_ID = 서비스 계정과 '공유'한 드라이브 폴더 ID
# NEXT_PUBLIC_DRIVE_ENABLED=true
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_DRIVE_ROOT_FOLDER_ID=
# (선택) 영역별로 다른 폴더에 넣고 싶을 때만. 비우면 위 ROOT 폴더로 폴백.
# NEXT_PUBLIC_CUSTOMERS_DRIVE_FOLDER_ID=
# BUSINESS_CARD_DRIVE_FOLDER_ID=
# RESOURCE_LIBRARY_DRIVE_FOLDER_ID=

# (선택) 세금계산서 발행 - Bolta (시스템설정 화면에서 입력 권장)
# BOLTA_API_KEY=
# BOLTA_CUSTOMER_KEY=
# BOLTA_WEBHOOK_SECRET=
# BOLTA_SUPPLIER_MANAGER_EMAIL=

# (선택) Gmail/Google 캘린더 연동 - Google OAuth (구글 클라우드 OAuth 클라이언트)
# 없으면 메일/캘린더 연동 메뉴만 비활성. 핵심 사용에는 불필요.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# (선택) Slack 알림 (시스템설정 화면에서 입력 권장)
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# (선택) Cron 엔드포인트 보호 (Vercel 배포 시)
# CRON_SECRET=

# (선택) 웹훅 콜백용 앱 주소 (Vercel 배포 시)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
